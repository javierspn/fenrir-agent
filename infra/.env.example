# Fenrir 01-infra configuration. Copy to .env and fill with real values (never commit .env).
# Every var is REQUIRED and validated fail-fast at startup (fenrir/settings.py, SC-008).

# Password for the Postgres role that owns the fenrir_core database (superuser in compose).
DB_PASSWORD=change-me
# Password for the read-only grafana_ro Postgres role used by the dashboard datasource (FR-004a).
GRAFANA_DB_RO_PASSWORD=change-me
# Grafana admin (UI) password.
GRAFANA_PASSWORD=change-me
# External API key (judge/fallback; captured day one, unused in 01-infra).
ANTHROPIC_API_KEY=sk-ant-...
# Native Ollama endpoint for model pulls (runs outside compose for GPU access).
OLLAMA_HOST=http://host.docker.internal:11434
# Owner notification whitelist id (notification interface out of scope).
OWNER_TELEGRAM_CHAT_ID=123456789

# --- Connection details (have defaults; override if not using the compose stack) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fenrir_core
# DB_USER=postgres
