   "title": "Reuse rate  ·  ↑ = compounding",
   "datasource": {
    "type": "postgres",
    "uid": "fenrir_core"
   },
   "gridPos": {
    "h": 5,
    "w": 6,
    "x": 0,
    "y": 4
   },
   "fieldConfig": {
