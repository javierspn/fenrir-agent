   "targets": [
    {
     "format": "time_series",
     "datasource": {
      "type": "postgres",
      "uid": "fenrir_core"
     },
     "rawSql": "SELECT date_trunc('day',created_at) AS time, avg(CASE WHEN retrieval_abstraction_id IS NOT NULL THEN 100.0 ELSE 0.0 END) AS \"Reuse %\" FROM tasks WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1"
    }
   ]
